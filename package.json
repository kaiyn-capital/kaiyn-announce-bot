{
	"name": "kaiyn-announce-bot",
	"version": "1.0.0",
	"description": "Minimal Discord embed announcement bot.",
	"license": "MIT",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"lint": "biome lint --error-on-warnings .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit",
		"test": "node --test dist/**/*.test.js",
		"start": "node dist/index.js",
		"deploy": "npm run build && node dist/deploy-commands.js",
		"dev": "tsx watch src/index.ts"
	},
	"engines": {
		"node": ">=24 <25"
	},
	"dependencies": {
		"discord.js": "^14.26.4",
		"dotenv": "^16.6.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^24.12.4",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	}
}
