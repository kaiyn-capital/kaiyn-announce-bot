{
  "name": "kaiyn-announce-bot",
  "version": "1.0.0",
  "description": "Minimal Discord embed announcement bot.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "start": "node dist/index.js",
    "deploy": "npm run build && node dist/deploy-commands.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
